{
  "name": "rfq-tool-server",
  "version": "1.0.0",
  "description": "图片转RFQ文档 - 后端服务",
  "main": "app.js",
  "scripts": {
    "dev": "node --watch app.js",
    "start": "node app.js",
    "migrate": "npx knex migrate:latest --knexfile knexfile.js",
    "migrate:rollback": "npx knex migrate:rollback --knexfile knexfile.js",
    "seed": "npx knex seed:run --knexfile knexfile.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "knex": "^3.1.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.0",
    "pdfkit": "^0.15.0",
    "sharp": "^0.33.0",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.0"
  }
}
