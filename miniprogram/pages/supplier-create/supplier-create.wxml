<!-- pages/supplier-create/supplier-create.wxml -->
<view class="container">
  <view class="card">
    <view class="form-group">
      <text class="form-label">供应商名称 *</text>
      <input class="form-input" data-field="name" value="{{form.name}}" placeholder="公司全称" bindinput="onInput" />
    </view>
    <view class="form-group">
      <text class="form-label">联系人</text>
      <input class="form-input" data-field="contact_person" value="{{form.contact_person}}" placeholder="联系人姓名" bindinput="onInput" />
    </view>
    <view class="form-group">
      <text class="form-label">电话</text>
      <input class="form-input" data-field="phone" value="{{form.phone}}" type="number" placeholder="手机号" bindinput="onInput" />
    </view>
    <view class="form-group">
      <text class="form-label">邮箱</text>
      <input class="form-input" data-field="email" value="{{form.email}}" placeholder="email@company.com" bindinput="onInput" />
    </view>
    <view class="form-group">
      <text class="form-label">地址</text>
      <input class="form-input" data-field="address" value="{{form.address}}" placeholder="公司地址" bindinput="onInput" />
    </view>
    <view class="form-group">
      <text class="form-label">供应类别</text>
      <input class="form-input" data-field="categories" value="{{form.categories}}" placeholder="用逗号分隔，如: 电子元件, PCB, 连接器" bindinput="onInput" />
    </view>
    <view class="form-group">
      <text class="form-label">备注</text>
      <textarea class="form-textarea" data-field="notes" value="{{form.notes}}" placeholder="备注信息..." bindinput="onInput" />
    </view>
  </view>

  <button class="btn-primary" bindtap="onSubmit" loading="{{saving}}">
    {{isEdit ? '保存修改' : '创建供应商'}}
  </button>
</view>
