<!-- pages/profile/profile.wxml -->
<view class="container">
  <!-- User Info -->
  <view class="card">
    <view class="flex-row">
      <view class="avatar">👤</view>
      <view class="ml-12">
        <text class="font-bold" style="font-size:16px;">{{isLoggedIn ? '已登录' : '未登录'}}</text>
        <text class="text-secondary text-sm" style="display:block;">
          {{isLoggedIn ? '微信小程序用户' : '请先登录以使用全部功能'}}
        </text>
      </view>
    </view>
    <button wx:if="{{!isLoggedIn}}" class="btn-primary mt-12" bindtap="onLogin">登录</button>
    <button wx:if="{{isLoggedIn}}" class="btn-default mt-12" bindtap="onLogout">退出登录</button>
  </view>

  <!-- Open API Section -->
  <view class="card mt-12">
    <view class="section-title mb-12">开放 API（给第三方网站调用）</view>
    <view class="info-row flex-between">
      <text>API 地址</text>
      <text class="text-secondary text-sm">{{serverUrl}}/openapi/v1</text>
    </view>
    <view class="info-row flex-between mt-8">
      <text>API Key</text>
      <text class="action-link" bindtap="onCopyApiKey">复制</text>
    </view>
    <view class="info-row flex-between mt-8">
      <text>接口文档</text>
      <text class="action-link" bindtap="onViewApiDocs">查看 Swagger</text>
    </view>
  </view>

  <!-- About -->
  <view class="card mt-12">
    <view class="section-title mb-12">关于</view>
    <view class="info-row">
      <text>版本</text>
      <text class="text-secondary text-sm ml-8">v1.0.0</text>
    </view>
    <view class="info-row mt-8">
      <text>功能</text>
      <text class="text-secondary text-sm ml-8">图片转RFQ询价单 - AI智能识别</text>
    </view>
  </view>
</view>
