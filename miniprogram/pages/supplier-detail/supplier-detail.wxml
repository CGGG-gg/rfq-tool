<!-- pages/supplier-detail/supplier-detail.wxml -->
<view wx:if="{{!loading}}" class="container">
  <!-- Supplier Info -->
  <view class="card">
    <view class="flex-between">
      <text class="supplier-name">{{supplier.name}}</text>
      <view class="flex-row">
        <text class="action-link mr-12" bindtap="onEdit">编辑</text>
        <text class="action-link danger" bindtap="onDelete">删除</text>
      </view>
    </view>

    <view wx:if="{{supplier.contact_person}}" class="mt-12">
      <text class="text-secondary text-sm">联系人: {{supplier.contact_person}}</text>
    </view>
    <view wx:if="{{supplier.phone}}" class="mt-8">
      <text class="text-secondary text-sm">电话: {{supplier.phone}}</text>
    </view>
    <view wx:if="{{supplier.email}}" class="mt-8">
      <text class="text-secondary text-sm">邮箱: {{supplier.email}}</text>
    </view>
    <view wx:if="{{supplier.address}}" class="mt-8">
      <text class="text-secondary text-sm">地址: {{supplier.address}}</text>
    </view>

    <view wx:if="{{categories.length > 0}}" class="mt-12">
      <text wx:for="{{categories}}" wx:key="*this" class="category-tag">{{item}}</text>
    </view>
  </view>

  <!-- Associated RFQs -->
  <view class="section">
    <text class="section-title">关联询价单 ({{rfqs.length}})</text>
    <view wx:if="{{rfqs.length > 0}}" class="mt-8">
      <view wx:for="{{rfqs}}" wx:key="id" class="card rfq-mini" data-id="{{item.id}}" bindtap="onTapRfq">
        <view class="flex-between">
          <text>{{item.title}}</text>
          <text class="text-sm" style="color:{{item.responded ? '#07c160' : '#999'}}">
            {{item.responded ? '已报价' : '未回复'}}
          </text>
        </view>
        <text class="text-secondary text-sm">{{item.status}} | {{formatDate(item.sent_at)}}</text>
      </view>
    </view>
    <view wx:else class="empty-state" style="padding:20px">
      <text class="text-secondary text-sm">暂无关联询价单</text>
    </view>
  </view>
</view>

<view wx:if="{{loading}}" class="loading">
  <text>加载中...</text>
</view>
