<view class="page">

  <!-- 步骤 -->
  <view class="steps">
    <view class="step {{error||recognized||recognizing?'done':''}} {{!imagePath&&!recognized?'active':''}}"><text class="num">1</text>上传</view>
    <view class="step {{recognized?'done':''}} {{recognizing?'active':''}}"><text class="num">2</text>识别</view>
    <view class="step {{recognized?'active':''}}"><text class="num">3</text>下载</view>
  </view>

  <!-- 上传 -->
  <view wx:if="{{!imagePath&&!recognizing&&!recognized&&!error}}" class="upload-zone" bindtap="chooseImage">
    <text class="upload-icon">📷</text>
    <text class="upload-text">点击拍照或选择图片</text>
    <text class="upload-hint">JPG / PNG · 最大 10MB</text>
  </view>

  <!-- 预览 -->
  <view wx:if="{{imagePath&&!recognizing&&!recognized}}" class="preview-wrap">
    <image src="{{imagePath}}" mode="widthFix" class="preview-img"/>
    <view class="preview-btns">
      <button class="pbtn pbtn-outline" bindtap="chooseImage">重新选择</button>
      <button class="pbtn pbtn-primary" bindtap="startRecognize">开始识别</button>
    </view>
  </view>

  <!-- 识别中 -->
  <view wx:if="{{recognizing}}" class="loading-box">
    <view class="spinner"></view>
    <text class="loading-title">AI 分析中...</text>
    <text class="loading-sub">DeepSeek + Kimi 并行处理</text>
  </view>

  <!-- 错误 -->
  <view wx:if="{{error}}" class="err-box">
    <text class="err-icon">😞</text>
    <text>{{error}}</text>
    <button class="retry-btn" bindtap="reset">重新上传</button>
  </view>

  <!-- 结果 -->
  <view wx:if="{{recognized&&items.length>0}}">
    <view class="result-head">
      <text class="result-label">识别结果</text>
      <text class="result-source">{{source}}</text>
    </view>

    <view wx:for="{{items}}" wx:key="index" class="item-card">
      <input class="inp inp-name" value="{{item.product_name}}" data-index="{{index}}" data-field="product_name" bindinput="onItemChange" placeholder="产品名称"/>
      <view class="item-row">
        <input class="inp inp-qty" value="{{item.quantity}}" type="digit" data-index="{{index}}" data-field="quantity" bindinput="onItemChange" placeholder="数量"/>
        <input class="inp inp-unit" value="{{item.unit}}" data-index="{{index}}" data-field="unit" bindinput="onItemChange" placeholder="单位"/>
        <input class="inp inp-price" value="{{item.target_price}}" type="digit" data-index="{{index}}" data-field="target_price" bindinput="onItemChange" placeholder="单价"/>
      </view>
      <input class="inp" value="{{item.specification}}" data-index="{{index}}" data-field="specification" bindinput="onItemChange" placeholder="规格型号"/>
    </view>

    <view class="dl-section">
      <button class="dl-btn dl-excel" bindtap="downloadExcel">📥 下载 Excel 询价单</button>
      <button class="dl-btn dl-pdf" bindtap="downloadPDF">📥 下载 PDF 询价单</button>
      <button class="dl-btn dl-reset" bindtap="reset">重新上传</button>
    </view>
  </view>

  <view class="footer">识别结果由 AI 生成，请核对后使用</view>
</view>
