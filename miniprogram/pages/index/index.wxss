page{background:#fff;font-family:-apple-system,sans-serif;font-size:15px;color:#1a1a1a}
.page{padding:20px 16px 32px}

/* 步骤 */
.steps{display:flex;justify-content:center;gap:12px;margin-bottom:24px}
.step{display:flex;align-items:center;gap:6px;font-size:12px;color:#bbb}
.step .num{width:20px;height:20px;border-radius:50%;background:#e5e5e5;color:#999;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center}
.step.done .num{background:#07c160;color:#fff}
.step.active .num{background:#1989fa;color:#fff}
.step.active{color:#333;font-weight:500}

/* 上传 */
.upload-zone{border:2px dashed #d9d9d9;border-radius:14px;padding:60px 24px;text-align:center;background:#fafbfc}
.upload-icon{font-size:44px;display:block;margin-bottom:14px}
.upload-text{font-size:15px;font-weight:600;display:block}
.upload-hint{font-size:12px;color:#999;margin-top:6px;display:block}

/* 预览 */
.preview-wrap{margin-bottom:16px}
.preview-img{width:100%;border-radius:10px;display:block}
.preview-btns{display:flex;gap:10px;margin-top:12px}
.pbtn{flex:1;height:46px;border-radius:10px;font-size:15px;font-weight:600;border:none;line-height:46px;text-align:center}
.pbtn-outline{background:#fff;color:#666;border:1px solid #ddd}
.pbtn-primary{background:#1989fa;color:#fff}

/* 加载 */
.loading-box{text-align:center;padding:40px 0}
.spinner{width:36px;height:36px;border:3px solid #e8e8e8;border-top-color:#1989fa;border-radius:50%;animation:spin .7s linear infinite;margin:0 auto 14px}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-title{font-size:15px;display:block}
.loading-sub{font-size:12px;color:#999;margin-top:4px;display:block}

/* 结果 */
.result-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px}
.result-label{font-size:16px;font-weight:700}
.result-source{font-size:11px;color:#07c160;background:#e8ffe8;padding:3px 8px;border-radius:10px}

.item-card{background:#f7f8fa;border-radius:10px;padding:14px;margin-bottom:10px}
.inp{width:100%;height:42px;border:1px solid #e0e0e0;border-radius:8px;padding:0 10px;font-size:14px;background:#fff;margin-bottom:8px}
.inp-name{font-weight:600;font-size:15px}
.item-row{display:flex;gap:8px}
.inp-qty{width:90px}.inp-unit{width:70px}.inp-price{flex:1}

/* 下载 */
.dl-section{margin-top:20px}
.dl-btn{width:100%;height:50px;border-radius:12px;font-size:16px;font-weight:600;text-align:center;line-height:50px;margin-bottom:10px;border:none}
.dl-excel{background:#07c160;color:#fff}
.dl-pdf{background:#fff;color:#1989fa;border:1px solid #1989fa}
.dl-reset{background:none;color:#999;font-size:14px;font-weight:400;height:40px;line-height:40px}

/* 错误 */
.err-box{text-align:center;padding:24px;color:#ee0a24;font-size:14px}
.err-box .err-icon{font-size:32px;display:block;margin-bottom:8px}
.retry-btn{margin-top:12px;height:42px;border-radius:10px;background:#1989fa;color:#fff;font-size:14px;border:none;line-height:42px;text-align:center}

.footer{text-align:center;padding:16px;color:#ccc;font-size:11px}
.hidden{display:none!important}
