.page { padding: 20px 16px; min-height: 100vh; }

/* 头部 */
.header { text-align: center; margin-bottom: 24px; }
.title { font-size: 22px; font-weight: 700; display: block; }
.subtitle { font-size: 13px; color: #999; margin-top: 6px; display: block; }

/* 上传按钮 */
.upload-section { margin-bottom: 16px; }
.upload-btn {
  border: 2px dashed #ccc; border-radius: 16px;
  padding: 60px 20px; text-align: center;
  transition: all .2s;
}
.upload-btn:active { border-color: #1989fa; background: #f0f7ff; }
.upload-icon { font-size: 48px; display: block; margin-bottom: 12px; }
.upload-text { font-size: 15px; font-weight: 600; display: block; }
.upload-hint { font-size: 12px; color: #bbb; margin-top: 8px; display: block; }

/* 预览 */
.preview-box { text-align: center; }
.preview-img { width: 100%; border-radius: 12px; box-shadow: 0 2px 10px rgba(0,0,0,.08); }
.preview-actions { display: flex; gap: 10px; margin-top: 14px; }
.act-btn { flex: 1; border-radius: 10px; padding: 14px; font-size: 15px; font-weight: 600; border: none; }
.act-repick { background: #f0f0f0; color: #666; }
.act-go { background: #1989fa; color: #fff; }

/* 加载 */
.loading-box { text-align: center; padding: 40px 0; }
.spinner {
  width: 36px; height: 36px; border: 4px solid #e0e0e0;
  border-top: 4px solid #1989fa; border-radius: 50%;
  animation: spin .8s linear infinite; margin: 0 auto 16px;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 15px; display: block; }
.loading-sub { font-size: 12px; color: #999; margin-top: 6px; display: block; }

/* 错误 */
.error-box { text-align: center; padding: 24px; color: #ee0a24; font-size: 14px; }
.retry-btn { margin-top: 12px; background: #1989fa; color: #fff; border-radius: 8px; font-size: 14px; }

/* 结果 */
.result-section { margin-top: 16px; }
.result-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.result-title { font-size: 16px; font-weight: 600; }
.result-source { font-size: 11px; color: #999; }

.item-card {
  background: #f9fafb; border-radius: 12px;
  padding: 14px; margin-bottom: 10px;
}
.item-input {
  width: 100%; border: 1px solid #e0e0e0; border-radius: 8px;
  padding: 10px; font-size: 14px; background: #fff;
  margin-bottom: 8px;
}
.name-input { font-weight: 600; font-size: 15px; }
.item-row { display: flex; gap: 8px; }
.qty-input { flex: 1; }
.unit-input { width: 80px; }
.price-input { flex: 1.5; }

/* 下载按钮 */
.download-section { margin-top: 20px; padding-bottom: 30px; }
.dl-btn {
  width: 100%; border-radius: 10px; padding: 15px;
  font-size: 16px; font-weight: 600; text-align: center;
  margin-bottom: 10px; border: none;
}
.dl-excel { background: #07c160; color: #fff; }
.dl-pdf { background: #fff; color: #1989fa; border: 1px solid #1989fa; }
.dl-retry { background: #f0f0f0; color: #666; }
