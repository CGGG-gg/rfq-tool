/* pages/rfq-detail/rfq-detail.wxss */
.rfq-title {
  font-size: 18px;
  font-weight: 600;
  flex: 1;
}

.status-badge {
  padding: 4px 12px;
  border-radius: 12px;
  color: #fff;
  font-size: 12px;
}

.rfq-notes {
  padding: 8px;
  background: #f7f8fa;
  border-radius: 4px;
}

.section {
  margin-top: 16px;
}

.section-header {
  margin-bottom: 8px;
}

.section-title {
  font-size: 15px;
  font-weight: 600;
  color: #333;
}

.action-link {
  font-size: 14px;
  color: #1989fa;
}

.action-link.danger {
  color: #ee0a24;
}

.item-card {
  border-left: 3px solid #07c160;
}

.item-name {
  font-weight: 500;
  flex: 1;
}

.item-qty {
  font-weight: 600;
  color: #1989fa;
}

.image-scroll {
  white-space: nowrap;
  padding: 8px 0;
}

.image-item {
  display: inline-block;
  position: relative;
  margin-right: 8px;
}

.preview-image {
  width: 80px;
  height: 80px;
  border-radius: 6px;
}

.image-delete {
  position: absolute;
  top: -6px;
  right: -6px;
  width: 20px;
  height: 20px;
  line-height: 20px;
  text-align: center;
  background: #ee0a24;
  color: #fff;
  border-radius: 50%;
  font-size: 12px;
}

.supplier-row {
  padding: 12px 0;
  border-bottom: 1px solid #f0f0f0;
}

/* Action bar at bottom */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.06);
}

/* Add padding bottom so content isn't hidden behind action bar */
.container {
  padding-bottom: 120px;
}
