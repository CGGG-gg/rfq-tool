<!-- pages/rfq-detail/rfq-detail.wxml -->
<view wx:if="{{!loading}}" class="container">
  <!-- Header -->
  <view class="card">
    <view class="flex-between">
      <text class="rfq-title">{{rfq.title}}</text>
      <view class="status-badge" style="background-color: {{getStatusInfo(rfq.status).color}}">
        {{getStatusInfo(rfq.status).text}}
      </view>
    </view>
    <view wx:if="{{rfq.notes}}" class="rfq-notes mt-8">
      <text class="text-secondary text-sm">{{rfq.notes}}</text>
    </view>
    <view class="rfq-meta mt-8">
      <text class="text-secondary text-sm">创建: {{rfq.created_at}}</text>
    </view>
  </view>

  <!-- Items Section -->
  <view class="section">
    <view class="section-header flex-between">
      <text class="section-title">行项目 ({{items.length}})</text>
      <view class="flex-row">
        <text class="action-link mr-8" bindtap="onScanImage">📷 拍照识别</text>
        <text class="action-link" bindtap="onAddItem">+ 添加</text>
      </view>
    </view>

    <view wx:if="{{items.length > 0}}">
      <view wx:for="{{items}}" wx:key="id" class="card item-card">
        <view class="flex-between">
          <text class="item-name">{{item.product_name}}</text>
          <text class="item-qty">x{{item.quantity}} {{item.unit}}</text>
        </view>
        <view wx:if="{{item.specification}}" class="text-secondary text-sm mt-8">
          规格: {{item.specification}}
        </view>
        <view class="flex-between mt-8">
          <text class="text-secondary text-sm">
            <text wx:if="{{item.target_price}}">目标单价: ¥{{item.target_price}}</text>
            <text wx:if="{{item.delivery_date}}"> | 交期: {{item.delivery_date}}</text>
          </text>
          <view class="flex-row">
            <text class="action-link mr-12" data-item-id="{{item.id}}" bindtap="onEditItem">编辑</text>
            <text class="action-link danger" data-item-id="{{item.id}}" bindtap="onDeleteItem">删除</text>
          </view>
        </view>
      </view>
    </view>
    <view wx:else class="empty-state" style="padding: 20px;">
      <text class="text-secondary text-sm">暂无行项目，点击上方按钮添加</text>
    </view>
  </view>

  <!-- Images Section -->
  <view class="section" wx:if="{{images.length > 0}}">
    <view class="section-header">
      <text class="section-title">原始图片 ({{images.length}})</text>
    </view>
    <scroll-view scroll-x="true" class="image-scroll">
      <view wx:for="{{images}}" wx:key="id" class="image-item">
        <image src="http://localhost:3000/{{item.file_path}}" mode="aspectFill" class="preview-image" />
        <text class="image-delete" data-image-id="{{item.id}}" bindtap="onDeleteImage">✕</text>
      </view>
    </scroll-view>
  </view>

  <!-- Suppliers Section -->
  <view class="section" wx:if="{{suppliers.length > 0}}">
    <view class="section-header flex-between">
      <text class="section-title">供应商 ({{suppliers.length}})</text>
      <text class="action-link" bindtap="onViewQuotes">查看报价</text>
    </view>
    <view wx:for="{{suppliers}}" wx:key="id" class="supplier-row flex-between">
      <view>
        <text>{{item.supplier_name}}</text>
        <text class="text-secondary text-sm ml-8">{{item.supplier_contact_person || ''}}</text>
      </view>
      <text class="text-sm" style="color: {{item.responded ? '#07c160' : '#999'}}">
        {{item.responded ? '已报价 ¥' + item.quote_amount : '未回复'}}
      </text>
    </view>
  </view>
</view>

<!-- Loading -->
<view wx:if="{{loading}}" class="loading">
  <text>加载中...</text>
</view>

<!-- Action Bar -->
<view wx:if="{{!loading}}" class="action-bar">
  <block wx:if="{{rfq.status === 'draft'}}">
    <button class="btn-primary" bindtap="onAddItem">添加行项目</button>
    <button class="btn-primary" style="margin-top:8px" bindtap="onSendRfq">发送给供应商</button>
  </block>
  <block wx:if="{{rfq.status === 'sent' || rfq.status === 'quoted'}}">
    <button class="btn-default" bindtap="onViewQuotes">查看报价情况</button>
    <button class="btn-danger" style="margin-top:8px" bindtap="onCloseRfq">关闭询价</button>
  </block>
  <block wx:if="{{rfq.status === 'quoted' || rfq.status === 'closed'}}">
    <button class="btn-default" data-type="excel" bindtap="onExport">导出 Excel</button>
    <button class="btn-default" style="margin-top:8px" data-type="pdf" bindtap="onExport">导出 PDF</button>
  </block>
</view>
