<!-- pages/image-recognize/image-recognize.wxml -->
<view class="container">
  <!-- Step 1: Take/Choose Photo -->
  <view wx:if="{{!imagePath}}" class="step-area">
    <text class="step-title">📷 拍照或选择产品规格图片</text>
    <text class="text-secondary text-sm mt-8">支持JPEG、PNG格式，拍照时请尽量清晰</text>
    <button class="btn-primary mt-16" bindtap="onChooseImage" style="width:200px;">
      {{true ? '拍照 / 选图' : ''}}
    </button>
  </view>

  <!-- Step 2: Preview & Upload -->
  <view wx:if="{{imagePath && !recognized}}" class="step-area">
    <image src="{{imagePath}}" mode="widthFix" class="preview-full" />
    <view class="flex-row mt-16" style="justify-content:center;">
      <button class="btn-default" bindtap="onChooseImage" style="width:120px;">重选</button>
      <button wx:if="{{!imageUploaded}}" class="btn-primary ml-8" bindtap="onUploadImage" style="width:120px;">上传</button>
      <button wx:if="{{imageUploaded}}" class="btn-primary ml-8" bindtap="onRecognize" style="width:120px;"
        loading="{{recognizing}}">
        {{recognizing ? '识别中...' : '开始识别'}}
      </button>
    </view>
  </view>

  <!-- Step 3: Review & Edit Recognized Items -->
  <view wx:if="{{recognized && editingItems.length > 0}}" class="step-area">
    <view class="flex-between mb-12">
      <text class="step-title">识别结果 ({{source === 'deepseek' ? 'AI' : 'OCR'}})</text>
      <text class="text-secondary text-sm">请检查并修改</text>
    </view>

    <view wx:for="{{editingItems}}" wx:key="index" class="card edit-card">
      <view class="flex-between mb-8">
        <text class="font-bold">{{index + 1}}. {{item.product_name || '(无名称)'}}</text>
        <text class="action-link danger" data-index="{{index}}" bindtap="onRemoveItem">删除</text>
      </view>

      <view class="form-group">
        <text class="form-label">产品名称</text>
        <input class="form-input" value="{{item.product_name}}" data-index="{{index}}"
          data-field="product_name" bindinput="onItemFieldChange" />
      </view>
      <view class="form-group">
        <text class="form-label">规格型号</text>
        <input class="form-input" value="{{item.specification}}" data-index="{{index}}"
          data-field="specification" bindinput="onItemFieldChange" />
      </view>
      <view class="flex-row">
        <view class="form-group" style="flex:1;margin-right:8px;">
          <text class="form-label">数量</text>
          <input class="form-input" value="{{item.quantity}}" type="digit" data-index="{{index}}"
            data-field="quantity" bindinput="onItemFieldChange" />
        </view>
        <view class="form-group" style="width:80px;">
          <text class="form-label">单位</text>
          <input class="form-input" value="{{item.unit}}" data-index="{{index}}"
            data-field="unit" bindinput="onItemFieldChange" />
        </view>
      </view>
      <view class="form-group">
        <text class="form-label">目标单价</text>
        <input class="form-input" value="{{item.target_price}}" type="digit" data-index="{{index}}"
          data-field="target_price" bindinput="onItemFieldChange" />
      </view>
      <view class="form-group">
        <text class="form-label">交货日期</text>
        <input class="form-input" value="{{item.delivery_date}}" data-index="{{index}}"
          data-field="delivery_date" bindinput="onItemFieldChange" />
      </view>
    </view>

    <!-- Confirm Actions -->
    <view class="form-actions">
      <button class="btn-primary" bindtap="onConfirm">确认导入 ({{editingItems.length}} 项)</button>
      <button class="btn-default mt-12" bindtap="onCancel">取消</button>
    </view>
  </view>

  <!-- Empty recognition result -->
  <view wx:if="{{recognized && editingItems.length === 0}}" class="empty-state">
    <text class="empty-icon">🤔</text>
    <text class="empty-text">未能识别到产品信息</text>
    <text class="text-secondary text-sm mt-8">请尝试使用更清晰的图片重试</text>
    <button class="btn-primary mt-16" bindtap="onChooseImage">重试</button>
  </view>
</view>
