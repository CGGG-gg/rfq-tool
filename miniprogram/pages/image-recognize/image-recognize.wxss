/* pages/image-recognize/image-recognize.wxss */
.step-area {
  padding: 0 0 20px 0;
}

.step-title {
  font-size: 16px;
  font-weight: 600;
}

.preview-full {
  width: 100%;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.edit-card {
  background: #fffdf0;
  border: 1px solid #ffeeba;
  margin-bottom: 12px;
}

.action-link {
  font-size: 14px;
  color: #1989fa;
}

.action-link.danger {
  color: #ee0a24;
}

.form-actions {
  margin-top: 16px;
  padding-bottom: 40px;
}
