/* pages/send-rfq/send-rfq.wxss */
.search-bar {
  margin-bottom: 12px;
}

.search-input {
  width: 100%;
  height: 40px;
  padding: 0 12px;
  border: 1px solid #ebedf0;
  border-radius: 6px;
  font-size: 14px;
  box-sizing: border-box;
  background-color: #fff;
}

.action-link {
  font-size: 14px;
  color: #1989fa;
}

.supplier-select-row {
  display: flex;
  align-items: center;
}

.checkbox {
  width: 22px;
  height: 22px;
  border: 2px solid #ddd;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
}

.checkbox.checked {
  background: #1989fa;
  border-color: #1989fa;
  color: #fff;
}

.send-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2px 8px rgba(0,0,0,0.06);
}

.container {
  padding-bottom: 100px;
}
